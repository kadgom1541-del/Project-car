<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 730" width="500" height="730">
  <defs>
    <style>
      .title { font-family: 'Sukhumvit Set', 'Prompt', 'Kanit', 'Noto Sans Thai', sans-serif; font-weight: 800; }
      .text-teal { fill: #129A98; font-family: 'Sukhumvit Set', 'Prompt', 'Kanit', 'Noto Sans Thai', sans-serif; }
      .text-dark { fill: #2D3748; font-family: 'Sukhumvit Set', 'Prompt', 'Kanit', 'Noto Sans Thai', sans-serif; }
      .text-gray { fill: #718096; font-family: 'Sukhumvit Set', 'Prompt', 'Kanit', 'Noto Sans Thai', sans-serif; }
      .text-light { fill: #A0AEC0; font-family: 'Sukhumvit Set', 'Prompt', 'Kanit', 'Noto Sans Thai', sans-serif; }
    </style>
  </defs>

  <!-- Card Outer Background -->
  <rect width="500" height="730" fill="#FFFFFF" rx="16" />

  <!-- Top Blue Header Bar -->
  <path d="M 0 16 A 16 16 0 0 1 16 0 L 484 0 A 16 16 0 0 1 500 16 L 500 90 L 0 90 Z" fill="#0C3859" />

  <!-- Thai QR Logo Emblem in Header -->
  <g transform="translate(90, 25)">
    <rect x="0" y="0" width="40" height="40" rx="8" fill="none" stroke="#FFFFFF" stroke-width="3" />
    <path d="M 10 10 L 30 10 L 30 30 L 10 30 Z" fill="none" stroke="#FFFFFF" stroke-width="2.5" />
    <polygon points="22,22 34,34 22,34" fill="#129A98" />
  </g>
  <text x="148" y="52" fill="#FFFFFF" font-size="22" class="title" letter-spacing="1">THAI QR PAYMENT</text>

  <!-- PromptPay Logo Badge -->
  <g transform="translate(180, 110)">
    <rect x="0" y="0" width="140" height="34" rx="4" fill="#FFFFFF" stroke="#CBD5E0" stroke-width="1.5" />
    <text x="18" y="23" fill="#0C3859" font-size="16" font-weight="900" font-family="sans-serif">Prompt</text>
    <text x="82" y="23" fill="#129A98" font-size="16" font-weight="900" font-family="sans-serif">Pay</text>
  </g>

  <!-- QR Code Section -->
  <g transform="translate(100, 155)">
    <rect x="0" y="0" width="300" height="300" fill="#FFFFFF" />
    <svg width="300" height="300" viewBox="0 0 37 37">
      <path fill="#FFFFFF" d="M0 0h31v31H0z"/><path stroke="#000000" d="M1 1.5h7m2 0h1m1 0h1m3 0h6m1 0h7M1 2.5h1m5 0h1m3 0h1m1 0h2m2 0h3m3 0h1m5 0h1M1 3.5h1m1 0h3m1 0h1m1 0h3m2 0h1m4 0h2m2 0h1m1 0h3m1 0h1M1 4.5h1m1 0h3m1 0h1m1 0h1m2 0h1m2 0h3m2 0h1m2 0h1m1 0h3m1 0h1M1 5.5h1m1 0h3m1 0h1m1 0h2m1 0h2m3 0h3m1 0h1m1 0h1m1 0h3m1 0h1M1 6.5h1m5 0h1m1 0h1m2 0h5m2 0h2m2 0h1m5 0h1M1 7.5h7m1 0h1m1 0h1m1 0h1m1 0h1m1 0h1m1 0h1m1 0h1m1 0h7M9 8.5h2m1 0h1m2 0h2m3 0h1M1 9.5h1m1 0h5m2 0h1m2 0h2m2 0h1m1 0h1m1 0h1m1 0h5M1 10.5h2m3 0h1m2 0h4m4 0h1m1 0h1m1 0h1m5 0h2M1 11.5h3m1 0h1m1 0h1m2 0h2m1 0h1m2 0h3m1 0h1m1 0h1m2 0h1m1 0h2M1 12.5h3m2 0h1m2 0h1m2 0h1m3 0h1m1 0h3m1 0h1m2 0h1m2 0h1M5 13.5h3m1 0h2m1 0h1m9 0h1m1 0h4M3 14.5h1m1 0h2m1 0h4m1 0h1m1 0h3m1 0h1m2 0h1m2 0h2m1 0h2M2 15.5h1m2 0h4m3 0h3m1 0h1m1 0h1m2 0h2m5 0h1M1 16.5h1m3 0h1m2 0h1m4 0h2m1 0h1m3 0h3m3 0h2m1 0h1M1 17.5h2m4 0h2m2 0h2m1 0h1m2 0h4m1 0h1m2 0h2m1 0h1M1 18.5h1m2 0h3m2 0h5m2 0h3m1 0h3m1 0h2m2 0h1M1 19.5h1m1 0h1m3 0h1m1 0h3m1 0h3m6 0h1m2 0h1m1 0h2M1 20.5h1m3 0h2m1 0h1m2 0h3m2 0h1m1 0h2m2 0h1m2 0h2m1 0h1M1 21.5h1m2 0h1m1 0h2m2 0h1m5 0h1m2 0h8m1 0h1M9 22.5h3m2 0h1m1 0h4m1 0h1m3 0h1m1 0h2M1 23.5h7m6 0h3m2 0h3m1 0h1m1 0h1m1 0h2M1 24.5h1m5 0h1m1 0h3m2 0h1m1 0h1m1 0h2m1 0h1m3 0h3M1 25.5h1m1 0h3m1 0h1m1 0h1m2 0h2m1 0h1m3 0h1m1 0h7M1 26.5h1m1 0h3m1 0h1m1 0h1m3 0h1m5 0h1m2 0h1m2 0h1m2 0h1M1 27.5h1m1 0h3m1 0h1m1 0h2m3 0h1m4 0h1m2 0h2m1 0h1m2 0h1M1 28.5h1m5 0h1m2 0h1m1 0h1m1 0h1m1 0h2m1 0h2m1 0h4m1 0h1M1 29.5h7m1 0h1m1 0h2m1 0h4m2 0h1m1 0h2m1 0h1m2 0h1"/>

    </svg>
  </g>

  <!-- PromptPay Logo Overlay in QR Center -->
  <g transform="translate(225, 280)">
    <rect x="-5" y="-5" width="60" height="60" rx="8" fill="#FFFFFF" stroke="#129A98" stroke-width="2" />
    <rect x="2" y="2" width="46" height="46" rx="4" fill="#0C3859" />
    <text x="25" y="28" fill="#129A98" font-size="20" font-weight="900" text-anchor="middle" font-family="sans-serif">PP</text>
  </g>

  <!-- Text Details Section -->
  <text x="250" y="490" text-anchor="middle" font-size="21" font-weight="700" class="text-teal">สแกน QR เพื่อโอนเข้าบัญชี</text>
  <text x="250" y="535" text-anchor="middle" font-size="22" font-weight="700" class="text-dark">ชื่อ: นาย เกียรติยศ ชุนเชิด</text>
  <text x="250" y="575" text-anchor="middle" font-size="19" font-weight="500" class="text-gray">บัญชี: xxx-x-x7437-x</text>
  <text x="250" y="610" text-anchor="middle" font-size="15" class="text-light">เลขที่อ้างอิง: 004999222186800</text>

  <!-- Bottom K+ Footer -->
  <line x1="0" y1="660" x2="500" y2="660" stroke="#00A950" stroke-width="3" />
  <g transform="translate(85, 680)">
    <text x="0" y="24" fill="#00A950" font-size="28" font-weight="900" font-family="sans-serif">K+</text>
    <text x="45" y="22" fill="#4A5568" font-size="15" font-weight="500" class="text-gray">Accepts all banks | รับเงินได้จากทุกธนาคาร</text>
  </g>
</svg>